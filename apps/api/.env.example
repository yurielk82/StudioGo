# 데이터베이스 (Neon)
DATABASE_URL=postgresql://user:password@host/studiogo?sslmode=require

# JWT (JWT_SECRET은 최소 32자)
JWT_SECRET=최소32자-랜덤문자열-여기에-입력
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# 카카오 OAuth
KAKAO_REST_API_KEY=카카오-REST-API-키
KAKAO_CLIENT_SECRET=카카오-Client-Secret

# 카카오 비즈메시지 (선택 — 알림톡 사용 시)
KAKAO_BIZ_APP_KEY=
KAKAO_BIZ_SENDER_KEY=

# Cron 보안
CRON_SECRET=로컬개발용-시크릿

# Expo Push (선택)
EXPO_ACCESS_TOKEN=

# 앱 URL
APP_URL=http://localhost:8081

# 에셋 (선택 — S3/R2 연동 시)
ASSET_PUBLIC_BASE_URL=
ASSET_UPLOAD_BASE_URL=

# 서버
PORT=3001

# 개발 전용 (프로덕션에서는 제거)
ALLOW_DEV_LOGIN=true
