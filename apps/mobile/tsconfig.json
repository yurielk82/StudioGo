{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@/*": ["./src/*"],
      "@domain/*": ["../../shared/domain/*"],
      "@domain": ["../../shared/domain"],
      "@contracts/*": ["../../shared/contracts/*"],
      "@contracts": ["../../shared/contracts"],
      "@constants/*": ["../../shared/constants/*"],
      "@constants": ["../../shared/constants"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../../shared/domain/**/*",
    "../../shared/contracts/**/*",
    "../../shared/constants/**/*",
    "nativewind-env.d.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": ["node_modules"]
}
