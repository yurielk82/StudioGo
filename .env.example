# ─── Database (Neon) ───
DATABASE_URL=postgresql://user:password@host/studiogo?sslmode=require

# ─── Auth (Kakao) ───
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://api.studiogo.kr/auth/kakao/callback

# ─── JWT ───
JWT_SECRET=your-secret-key-min-32-chars-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Kakao BizMessage ───
KAKAO_BIZ_APP_KEY=
KAKAO_BIZ_SENDER_KEY=

# ─── Expo Push ───
EXPO_ACCESS_TOKEN=

# ─── Vercel Cron ───
CRON_SECRET=

# ─── App URLs ───
API_URL=https://api.studiogo.kr
APP_URL=https://app.studiogo.kr

# ─── Client (Expo) ───
EXPO_PUBLIC_API_URL=https://api.studiogo.kr
EXPO_PUBLIC_KAKAO_APP_KEY=
